// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  // Prisma 7ではここにプレビュー機能が必要な場合があります
  previewFeatures = ["driverAdapters"] 
}

datasource db {
  provider = "postgresql"
  // ここにあった url = env("DATABASE_URL") を完全に削除してください
}

model Event {
  id          Int      @id @default(autoincrement())
  name        String
  date        DateTime
  location    String
  genre       String?
  memo        String?
  rating      Int      @default(5)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}